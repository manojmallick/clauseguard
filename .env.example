# ─────────────────────────────────────────────────────────────
# ClauseGuard environment — copy to .env.local and fill in.
# .env.local is git-ignored. Never commit real credentials.
# ─────────────────────────────────────────────────────────────

# Amazon Aurora PostgreSQL (Serverless v2) connection string.
# Must have the `vector` (pgvector) extension available.
# Example: postgres://USER:PASSWORD@your-cluster.cluster-xxxx.us-east-1.rds.amazonaws.com:5432/clauseguard
DATABASE_URL=

# Set to "require" for Aurora (TLS). Use "disable" only for a local dev Postgres.
PGSSLMODE=require

# ─────────────────────────────────────────────────────────────
# Amazon Bedrock (embeddings + LLM). Region must have model access granted.
# ─────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# Standard AWS credential resolution applies (env vars, shared config, or IAM role).
# For local dev you can set these explicitly:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=   # only if using temporary credentials

# Bedrock model IDs
BEDROCK_LLM_MODEL_ID=anthropic.claude-sonnet-4-6
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# Embedding dimension. Titan v2 supports 256 / 512 / 1024. Must match db/schema.sql vector(N).
EMBED_DIM=1024

# RAG tuning — beyond this cosine distance, the nearest pattern is too weak to ground on (abstain).
RAG_DISTANCE_FLOOR=0.55
# Prior-exposure: a past org clause closer than this counts as "you accepted this before".
RAG_PRIOR_EXPOSURE_MAX=0.45
