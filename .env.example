# ─────────────────────────────────────────────────────────────
# ClauseGuard environment. Copy to .env.local (git-ignored).
# Never commit real credentials.
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# PREFERRED: Vercel Amazon Aurora PostgreSQL integration (IAM/OIDC, no password).
# These are injected when you connect the integration to the project; pull with:
#   vercel env pull .env.local
# PGHOST=...rds.amazonaws.com
# PGPORT=5432
# PGUSER=...
# PGDATABASE=postgres
# AWS_ROLE_ARN=arn:aws:iam::...:role/...
# VERCEL_OIDC_TOKEN=...   # provided by `vercel env pull` for local IAM auth (short-lived)

# FALLBACK: a plain connection string (local Postgres or generic Aurora).
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/clauseguard
# PGSSLMODE=require        # set "disable" for a local non-TLS Postgres

# ── Amazon Bedrock (embeddings + LLM) ─────────────────────────
# Region must have model access granted for the two models below.
AWS_REGION=us-east-1
# Bedrock credentials. On Vercel these can come from an OIDC role; for local
# `pnpm db:seed` you typically need a key/secret with bedrock:InvokeModel:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=      # only if using temporary credentials

BEDROCK_LLM_MODEL_ID=anthropic.claude-sonnet-4-6
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
EMBED_DIM=1024            # Titan v2 (256/512/1024). Must match db/schema.sql vector(N).

# ── AI provider switch ────────────────────────────────────────
# 'bedrock' (default, the AWS story) or 'openai' (fallback while awaiting Bedrock quota).
AI_PROVIDER=bedrock
# Only needed when AI_PROVIDER=openai:
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small   # projected to EMBED_DIM via `dimensions`
OPENAI_LLM_MODEL=gpt-4o-mini

# ── RAG tuning ────────────────────────────────────────────────
RAG_DISTANCE_FLOOR=0.55   # beyond this cosine distance, abstain (flag for human review)
RAG_PRIOR_EXPOSURE_MAX=0.45  # closer than this in the org's history = "you accepted this before"

# Optional: pin a specific tenant (printed by `pnpm db:seed`)
# ORG_ID=
