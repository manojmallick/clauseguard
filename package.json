{
  "name": "clauseguard",
  "version": "0.1.0",
  "private": true,
  "description": "AI contract-risk scanner — Aurora PostgreSQL + pgvector RAG grounded on Amazon Bedrock",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "db:schema": "node --env-file=.env.local scripts/run-sql.mjs db/schema.sql",
    "db:seed": "node --env-file=.env.local scripts/seed.mjs",
    "db:reset": "node --env-file=.env.local scripts/run-sql.mjs db/schema.sql && node --env-file=.env.local scripts/seed.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.658.0",
    "@aws-sdk/rds-signer": "^3.1073.0",
    "@base-ui/react": "^1.5.0",
    "@vercel/analytics": "1.6.1",
    "@vercel/functions": "^3.7.2",
    "@vercel/oidc-aws-credentials-provider": "^3.1.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "mammoth": "^1.8.0",
    "next": "16.2.6",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.1",
    "react": "^19",
    "react-dom": "^19",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^24",
    "@types/pg": "^8.11.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "postcss": "^8.5",
    "tailwindcss": "^4.2.0",
    "typescript": "5.7.3"
  },
  "pnpm": {
    "overrides": {
      "hono": "4.12.25"
    }
  }
}
